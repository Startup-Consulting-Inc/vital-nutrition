# ============================================================
# DEVELOPMENT MODE (default)
# ============================================================
# The frontend calls OpenRouter directly. Set your API key below.

# OpenRouter API Key for AI features (Label Analyzer + Chat)
# Get yours at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (optional, defaults to moonshotai/kimi-k2.6)
# Popular options:
#   moonshotai/kimi-k2.6          - Kimi K2.6 (default, good vision + reasoning)
#   anthropic/claude-3.5-sonnet   - Claude 3.5 Sonnet (excellent reasoning)
#   openai/gpt-4o                 - GPT-4o (strong vision capabilities)
#   google/gemini-2.0-flash-001   - Gemini 2.0 Flash (fast, free tier)
#   deepseek/deepseek-chat        - DeepSeek V3 (cost-effective)
# See full list at https://openrouter.ai/models
VITE_OPENROUTER_MODEL=moonshotai/kimi-k2.6

# ============================================================
# PRODUCTION MODE
# ============================================================
# Uncomment the line below to route all AI calls through Cloud
# Functions (Firebase). Secrets are stored in Google Secret Manager.
# No API key needed in the frontend.
#
# VITE_USE_CLOUD_FUNCTIONS=true
#
# Required secrets in Google Secret Manager:
#   openrouter-api-key  -> your OpenRouter API key
#   openrouter-model    -> model name (e.g. moonshotai/kimi-k2.6)
#
# Deploy functions:  firebase deploy --only functions
# Deploy hosting:    npm run build && firebase deploy --only hosting
#
# ============================================================
# Firebase config is in src/lib/firebase.ts
# Update it with your project's config from Firebase Console
